GROQ_API_KEY = "your-groq-api-key-here"
SERP_API_KEY = "your-serpapi-key-here"

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN = "your-whatsapp-access-token-here"
WHATSAPP_PHONE_NUMBER_ID = "your-phone-number-id-here"

# Email (SMTP — Gmail example; use an App Password, not your login password)
SMTP_USER = "your-email@gmail.com"
SMTP_PASSWORD = "your-app-password-here"

# Google Sheets (optional — only needed if agents read from Google Sheets)
# GOOGLE_CREDENTIALS_PATH = "/path/to/service-account.json"
